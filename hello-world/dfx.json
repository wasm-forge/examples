{
  "canisters": {
    "hello-world-backend": {
      "candid": "src/hello-world-backend/hello-world-backend.did",
      "package": "hello-world-backend",
      "build": [
        "cargo build --release --target wasm32-wasip1",
        "wasi2ic target/wasm32-wasip1/release/hello_world_backend.wasm target/wasm32-wasip1/release/no_wasi.wasm"],
      "wasm": "target/wasm32-wasip1/release/no_wasi.wasm",
      "type": "custom",
      "metadata": [
        {
          "name": "candid:service"
        }
      ]
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "output_env_file": ".env",
  "version": 1
}