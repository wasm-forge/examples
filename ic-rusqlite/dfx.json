{
  "canisters": {
    "ic-rusqlite-backend": {
      "candid": "src/ic-rusqlite-backend/ic-rusqlite-backend.did",
      "package": "ic-rusqlite-backend",
      "build": [
        "cargo build --release --target wasm32-wasip1",
        "wasi2ic target/wasm32-wasip1/release/ic_rusqlite_backend.wasm target/wasm32-wasip1/release/nowasi.wasm"
      ],
      "wasm": "target/wasm32-wasip1/release/nowasi.wasm",
      "type": "custom",
      "metadata": [
        {
          "name": "candid:service"
        }
      ]
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "output_env_file": ".env",
  "version": 1
  
}